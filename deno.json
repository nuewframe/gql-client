{
  "name": "@nuewframe/gql-client",
  "version": "1.1.0",
  "exports": "./main.ts",
  "tasks": {
    "dev": "deno run --allow-read --allow-write --allow-env --allow-net --allow-run main.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net --allow-run",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "build:current": "deno compile --allow-read --allow-write --allow-env --allow-net --allow-run --vendor --output dist/gql-client main.ts",
    "build:macos-x64": "deno compile --allow-read --allow-write --allow-env --allow-net --allow-run --target x86_64-apple-darwin --vendor --output dist/gql-client-macos-x64 main.ts",
    "build:macos-arm64": "deno compile --allow-read --allow-write --allow-env --allow-net --allow-run --target aarch64-apple-darwin --vendor --output dist/gql-client-macos-arm64 main.ts",
    "build:linux-x64": "deno compile --allow-read --allow-write --allow-env --allow-net --allow-run --target x86_64-unknown-linux-gnu --vendor --output dist/gql-client-linux-x64 main.ts",
    "build:windows-x64": "deno compile --allow-read --allow-write --allow-env --allow-net --allow-run --target x86_64-pc-windows-msvc --vendor --output dist/gql-client-windows-x64.exe main.ts",
    "build:all": "deno task build:macos-x64 && deno task build:macos-arm64 && deno task build:linux-x64 && deno task build:windows-x64"
  },
  "imports": {
    "@cliffy/command": "jsr:@cliffy/command@^1.0.0",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/cli": "jsr:@std/cli@^1.0.0",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/yaml": "jsr:@std/yaml@^1.0.12",
    "@std/jsonc": "jsr:@std/jsonc@^1.0.2",
    "graphql-request": "npm:graphql-request@^7.4.0"
  },
  "compilerOptions": {
    "strict": true,
    "lib": [
      "ES2022",
      "DOM",
      "deno.ns"
    ]
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "preserve"
  }
}
